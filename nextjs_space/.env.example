# Database (Supabase) - Get both from Supabase > Settings > Database
# Use the "Session mode" pooler URL for DATABASE_URL
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use the direct connection URL for DIRECT_URL (for migrations)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# AWS S3 (for proof-of-payment file uploads)
AWS_BUCKET_NAME="your-s3-bucket-name"
AWS_FOLDER_PREFIX="lotz-landgoed/"
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
